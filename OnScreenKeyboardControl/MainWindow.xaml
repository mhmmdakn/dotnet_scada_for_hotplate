<Window x:Class="OnScreenKeyboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:keyboard="clr-namespace:OnScreenKeyboard.Keyboard"
        xmlns:onScreenKeyboardControl="clr-namespace:OnScreenKeyboard"
        Title="MainWindow"
        Width="825"
        Height="450"
        mc:Ignorable="d">
    <Window.DataContext>
        <onScreenKeyboardControl:ViewModel/>
    </Window.DataContext>

    <Grid Name="MainGrid"
	      VerticalAlignment="Stretch">

        <keyboard:OnScreenKeyboard
		                           Height="215" 
		                           VerticalAlignment="Bottom" />
															 
		                           <!--ActiveContainer="{Binding ElementName=MainGrid}"
		                           CancelCommand="{Binding CancelCommand}"
		                           SaveCommand="{Binding SaveCommand}" Margin="132,0,120,23"--> 
        <TextBox HorizontalAlignment="Left" Height="23" Margin="174,52,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="120"/>
    </Grid>
</Window>
