<y:PLC_BaseUserControl x:Class="HotPlate.StateGif"
             xmlns:y="clr-namespace:Hot_Plate_Lib;assembly=Hot_Plate_Lib"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HotPlate"
             mc:Ignorable="d" 
             d:DesignHeight="120" d:DesignWidth="100">
    <Grid>
        <Image x:Name="img_state" Margin="0,20,0,0" Stretch="UniformToFill"/>
        <TextBlock x:Name="txt_state" TextWrapping="Wrap" FontSize="14" FontWeight="Bold" TextAlignment="Center" Margin="0,0,0,100"/>

    </Grid>
</y:PLC_BaseUserControl>
